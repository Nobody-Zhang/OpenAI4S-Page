---
import Layout from '~/layouts/PageLayout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const metadata = {
  title: '404 — page not found',
  ignoreTitleTemplate: true,
  robots: { index: false, follow: false },
  description: 'That route does not exist on openai4s.org.',
};
---

<Layout metadata={metadata}>
  <section class="flex items-center min-h-[70vh] p-8 md:p-16">
    <div class="container flex flex-col items-center justify-center mx-auto text-center">
      <div class="max-w-lg w-full">
        <h1 class="text-5xl md:text-6xl font-bold font-heading tracking-tight text-gray-900 dark:text-white mb-8">
          <span class="text-primary">404</span> — page not found
        </h1>
        <div class="nb-card text-left mx-auto max-w-md">
          <div class="nb-head">
            <span class="inline-flex items-center gap-2"
              ><span class="nb-dots"><i></i><i></i><i></i></span>kernel · python3</span
            >
            <span class="nb-live"><span class="nb-led"></span>alive</span>
          </div>
          <div class="nb-body">
            <pre><code><span class="tok-out">In [1]:</span> host.get_page(url)

<span class="tok-out">Out[1]:</span> <span class="tok-num">404</span> — <span class="tok-com">page not found in this kernel</span></code></pre>
          </div>
        </div>
        <p class="mt-8 text-lg text-muted">The cell ran, but that route doesn’t exist.</p>
        <div class="mt-6 flex justify-center">
          <a rel="noopener noreferrer" href={getHomePermalink()} class="btn-ghost">$ cd ~ &amp;&amp; open /</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
