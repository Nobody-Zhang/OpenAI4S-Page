---
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import CodeCard from '~/components/openai4s/CodeCard.astro';
import DemoVideo from '~/components/openai4s/DemoVideo.astro';
import BrandMark from '~/components/openai4s/BrandMark.astro';
import ParticleField from '~/components/openai4s/ParticleField.astro';
import HudBadge from '~/components/openai4s/HudBadge.astro';
import HeroTerminal from '~/components/openai4s/HeroTerminal.astro';
import ProviderOrbit from '~/components/openai4s/ProviderOrbit.astro';
import ParadigmCompare from '~/components/openai4s/ParadigmCompare.astro';
import ArchitectureFlow from '~/components/openai4s/ArchitectureFlow.astro';
import SkillHexGrid from '~/components/openai4s/SkillHexGrid.astro';
import PricingPanel from '~/components/openai4s/PricingPanel.astro';
import FaqGrid from '~/components/openai4s/FaqGrid.astro';
import StatCounter from '~/components/openai4s/StatCounter.astro';
import { Icon } from 'astro-icon/components';
import arkPlan from '~/assets/openai4s/ark-plan.png';
import { ui } from '~/i18n/dict';

const GITHUB = 'https://github.com/PKU-YuanGroup/OpenAI4S';
const ARCH = 'https://github.com/PKU-YuanGroup/OpenAI4S/blob/main/docs/architecture.md';
const DOCS = 'https://github.com/PKU-YuanGroup/OpenAI4S/tree/main/docs';
const t = ui;

const metadata = {
  title: 'OpenAI4S — Open AI for Scientist',
  ignoreTitleTemplate: true,
};

const heroCode = `<pre><code><span class="tok-out">In [1]:</span> <span class="tok-kw">from</span> openai4s <span class="tok-kw">import</span> agent

hits   = [f <span class="tok-kw">for</span> f <span class="tok-kw">in</span> files <span class="tok-kw">if</span> pattern <span class="tok-kw">in</span> <span class="tok-fn">host.read_file</span>(f)]
top3   = <span class="tok-fn">sorted</span>(hits, key=os.path.getsize, reverse=<span class="tok-kw">True</span>)[:<span class="tok-num">3</span>]
frames = [<span class="tok-fn">pd.read_csv</span>(f) <span class="tok-kw">for</span> f <span class="tok-kw">in</span> top3]
<span class="tok-fn">host.save_artifact</span>(<span class="tok-fn">plot</span>(frames))<span class="o4s-cursor"></span>

<span class="tok-out">Out[1]:</span> <span class="tok-str">&lt;DataFrame 100000×20&gt;</span> <span class="tok-com">stays resident — only the summary hits context</span></code></pre>`;

const paradigmCode = `<pre><code><span class="tok-com"># ReAct: ~14 round-trips.   OpenAI4S: one code cell.</span>
hits   = [f <span class="tok-kw">for</span> f <span class="tok-kw">in</span> files <span class="tok-kw">if</span> pattern <span class="tok-kw">in</span> <span class="tok-fn">host.read_file</span>(f)]
top3   = <span class="tok-fn">sorted</span>(hits, key=os.path.getsize, reverse=<span class="tok-kw">True</span>)[:<span class="tok-num">3</span>]
frames = [<span class="tok-fn">pd.read_csv</span>(f) <span class="tok-kw">for</span> f <span class="tok-kw">in</span> top3]
<span class="tok-fn">host.save_artifact</span>(<span class="tok-fn">plot</span>(frames))</code></pre>`;

const quickstart = `<pre><code><span class="tok-com">$</span> git clone https://github.com/PKU-YuanGroup/OpenAI4S <span class="tok-kw">&amp;&amp;</span> cd OpenAI4S
<span class="tok-com">$</span> ./setup.sh
<span class="tok-com">$</span> ./start.sh     <span class="tok-com"># http://127.0.0.1:8760/</span></code></pre>`;

const cmpRows = [
  { a: 'Action unit', r: 'One tool call (JSON)', c: '<strong>An arbitrary program</strong> (a code cell)' },
  { a: 'Action space', r: 'A fixed menu of tools', c: '<strong>A Turing-complete language</strong> (Python / R)' },
  {
    a: 'Loops &amp; composition',
    r: 'Orchestrated over many round-trips',
    c: 'Done <strong>in one cell</strong> — <code>for</code>, <code>if</code>, comprehensions',
  },
  {
    a: 'Intermediate state',
    r: "Lives in the model's context (text)",
    c: 'Lives in <strong>kernel memory</strong> (real objects)',
  },
  { a: 'Big objects', r: 'Serialized back into context', c: 'Stay resident; <strong>only a summary returns</strong>' },
  { a: 'N operations', r: '≈ N model round-trips', c: '<strong>One round-trip</strong> can do many steps' },
  { a: 'Extending tools', r: 'Change the schema + the host', c: '<code>import</code> a library, or read a Skill' },
];

const cmpRowsZh = [
  { a: '动作单元', r: '一次工具调用 (JSON)', c: '<strong>任意程序</strong>（一个代码单元）' },
  { a: '动作空间', r: '固定工具菜单', c: '<strong>图灵完备语言</strong>（Python / R）' },
  { a: '循环与组合', r: '多轮编排', c: '<strong>一个单元内完成</strong> — <code>for</code>、<code>if</code>' },
  { a: '中间状态', r: '存在模型上下文（文本）', c: '存在<strong>内核内存</strong>（真实对象）' },
  { a: '大对象', r: '序列化回上下文', c: '常驻；<strong>仅返回摘要</strong>' },
  { a: 'N 步操作', r: '≈ N 次模型往返', c: '<strong>一次往返</strong>可完成多步' },
  { a: '扩展工具', r: '改 schema + host', c: '<code>import</code> 库，或读取 Skill' },
];

const providers = ['doubao', 'glm', 'kimi', 'deepseek', 'minimax', 'chatgpt', 'claude', 'gemini'];

const skillGroups = [
  {
    label: t.en.skills_g1,
    items: ['alphafold2', 'openfold3', 'boltz', 'chai1', 'esmfold2'],
    icon: 'tabler:atom',
  },
  {
    label: t.en.skills_g2,
    items: ['fair-esm2', 'evo2', 'borzoi', 'scgpt', 'scvi-tools', 'diffdock'],
    icon: 'tabler:microscope',
  },
  { label: t.en.skills_g3, items: ['proteinmpnn', 'ligandmpnn', 'solublempnn'], icon: 'tabler:puzzle' },
  {
    label: t.en.skills_g4,
    items: [
      'literature-review',
      'paper-narrative',
      'indication-dossier',
      'pdf-explore',
      'figure-composer',
      'figure-style',
      'example_stats',
      'remote-compute-ssh',
      'remote-compute-nvidia',
      'using-model-endpoint',
    ],
    icon: 'tabler:notebook',
  },
];

const skillGroupsZh = [
  { ...skillGroups[0], label: t.zh.skills_g1 },
  { ...skillGroups[1], label: t.zh.skills_g2 },
  { ...skillGroups[2], label: t.zh.skills_g3 },
  { ...skillGroups[3], label: t.zh.skills_g4 },
];

const demos = [
  { src: '/demos/demo-01.mp4', poster: '/demos/demo-01-poster.jpg', label: 'session · 01', capKey: 'demo_1' as const },
  { src: '/demos/demo-05.mp4', poster: '/demos/demo-05-poster.jpg', label: 'session · 02', capKey: 'demo_2' as const },
  { src: '/demos/demo-02.mp4', poster: '/demos/demo-02-poster.jpg', label: 'session · 03', capKey: 'demo_3' as const },
  { src: '/demos/demo-06.mp4', poster: '/demos/demo-06-poster.jpg', label: 'session · 04', capKey: 'demo_4' as const },
  { src: '/demos/demo-03.mp4', poster: '/demos/demo-03-poster.jpg', label: 'session · 05', capKey: 'demo_5' as const },
  { src: '/demos/demo-04.mp4', poster: '/demos/demo-04-poster.jpg', label: 'session · 06', capKey: 'demo_6' as const },
];

const highlights = [
  { titleKey: 'h1_t' as const, descKey: 'h1_d' as const, icon: 'tabler:code' },
  { titleKey: 'h2_t' as const, descKey: 'h2_d' as const, icon: 'tabler:package' },
  { titleKey: 'h3_t' as const, descKey: 'h3_d' as const, icon: 'tabler:plug-connected' },
  { titleKey: 'h4_t' as const, descKey: 'h4_d' as const, icon: 'tabler:browser' },
  { titleKey: 'h5_t' as const, descKey: 'h5_d' as const, icon: 'tabler:cloud-cog' },
  { titleKey: 'h6_t' as const, descKey: 'h6_d' as const, icon: 'tabler:books' },
];

const stats = [
  { amount: '24', key: 'stat_1' as const },
  { amount: '14', key: 'stat_2' as const },
  { amount: '8', key: 'stat_3' as const },
  { amount: '206', key: 'stat_4' as const },
  { amount: '¥9.9', key: 'stat_5' as const },
  { amount: '0', key: 'stat_6' as const },
  { amount: 'MIT', key: 'stat_7' as const },
];

const faqsEn = [
  { title: t.en.faq1_t, description: t.en.faq1_d, icon: 'tabler:git-branch' },
  { title: t.en.faq2_t, description: t.en.faq2_d, icon: 'tabler:key' },
  { title: t.en.faq3_t, description: t.en.faq3_d, icon: 'tabler:switch-horizontal' },
  { title: t.en.faq4_t, description: t.en.faq4_d, icon: 'tabler:cpu' },
  { title: t.en.faq5_t, description: t.en.faq5_d, icon: 'tabler:packages' },
  { title: t.en.faq6_t, description: t.en.faq6_d, icon: 'tabler:shield-check' },
];
const faqsZh = [
  { title: t.zh.faq1_t, description: t.zh.faq1_d, icon: 'tabler:git-branch' },
  { title: t.zh.faq2_t, description: t.zh.faq2_d, icon: 'tabler:key' },
  { title: t.zh.faq3_t, description: t.zh.faq3_d, icon: 'tabler:switch-horizontal' },
  { title: t.zh.faq4_t, description: t.zh.faq4_d, icon: 'tabler:cpu' },
  { title: t.zh.faq5_t, description: t.zh.faq5_d, icon: 'tabler:packages' },
  { title: t.zh.faq6_t, description: t.zh.faq6_d, icon: 'tabler:shield-check' },
];
---

<Layout metadata={metadata}>
  <!-- ======================= HERO — IMAX void ======================= -->
  <section class="relative not-prose overflow-hidden min-h-[100svh] flex items-center">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-black"></div>
      <div class="o4s-aurora absolute inset-0"></div>
      <ParticleField density={96} />
      <div class="o4s-grid absolute inset-0"></div>
      <div class="o4s-glow absolute inset-0 opacity-70"></div>
      <div class="o4s-orb o4s-orb-a opacity-40"></div>
      <div class="o4s-orb o4s-orb-b opacity-30"></div>
      <div class="o4s-vignette absolute inset-0"></div>
      <div class="o4s-noise absolute inset-0"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 md:py-28 w-full">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-10 items-center">
        <div class="lg:col-span-6 text-center lg:text-left min-w-0">
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2 mb-8">
            <HudBadge label={t.en.hero_sys} value={t.en.hero_sys_v} tone="amber" class="o4s-i18n-en" />
            <HudBadge label={t.zh.hero_sys} value={t.zh.hero_sys_v} tone="amber" class="o4s-i18n-zh" />
            <HudBadge label={t.en.hero_kernel} value={t.en.hero_kernel_v} tone="cyan" class="o4s-i18n-en" />
            <HudBadge label={t.zh.hero_kernel} value={t.zh.hero_kernel_v} tone="cyan" class="o4s-i18n-zh" />
            <HudBadge label={t.en.hero_ark} value={t.en.hero_ark_v} tone="amber" class="o4s-i18n-en" />
            <HudBadge label={t.zh.hero_ark} value={t.zh.hero_ark_v} tone="amber" class="o4s-i18n-zh" />
          </div>

          <div class="flex items-center justify-center lg:justify-start gap-4 mb-7">
            <BrandMark size={52} motion="orbit" />
            <div class="text-left">
              <p class="o4s-cine-kicker">
                <span class="o4s-i18n-en">{t.en.hero_tagline}</span>
                <span class="o4s-i18n-zh">{t.zh.hero_tagline}</span>
              </p>
              <p class="font-mono text-[0.7rem] tracking-[0.18em] text-muted mt-1 uppercase opacity-70">
                <span class="o4s-i18n-en">{t.en.hero_type}</span>
                <span class="o4s-i18n-zh">{t.zh.hero_type}</span>
              </p>
            </div>
          </div>

          <h1 class="o4s-cine-title text-4xl sm:text-5xl xl:text-[3.65rem] font-heading">
            <span class="o4s-i18n-en block">{t.en.hero_h1_a}</span>
            <span class="o4s-i18n-zh block">{t.zh.hero_h1_a}</span>
            <span class="o4s-gradient-text">
              <span class="o4s-i18n-en">{t.en.hero_h1_b}</span>
              <span class="o4s-i18n-zh">{t.zh.hero_h1_b}</span>
            </span>
          </h1>

          <p class="o4s-cine-lead mt-7 mx-auto lg:mx-0">
            <span class="o4s-i18n-en">{t.en.hero_lead}</span>
            <span class="o4s-i18n-zh">{t.zh.hero_lead}</span>
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a
              href={GITHUB}
              target="_blank"
              rel="noopener"
              class="btn-primary inline-flex items-center justify-center gap-2"
            >
              <Icon name="tabler:brand-github" class="w-5 h-5" />
              <span class="o4s-i18n-en">{t.en.hero_cta_star}</span>
              <span class="o4s-i18n-zh">{t.zh.hero_cta_star}</span>
            </a>
            <a href="#quickstart" class="btn-ghost">
              <span class="o4s-i18n-en">{t.en.hero_cta_clone}</span>
              <span class="o4s-i18n-zh">{t.zh.hero_cta_clone}</span>
            </a>
          </div>

          <p class="mt-8 font-mono text-[0.68rem] tracking-[0.14em] uppercase text-muted">
            <span class="o4s-i18n-en">{t.en.hero_status}</span>
            <span class="o4s-i18n-zh">{t.zh.hero_status}</span>
          </p>
        </div>

        <div class="lg:col-span-6 w-full min-w-0 relative">
          <HeroTerminal label="kernel · python3 · host.rpc" live="alive">
            <Fragment set:html={heroCode} />
          </HeroTerminal>
          <div class="mt-5 flex flex-wrap gap-2 justify-center lg:justify-start">
            <span class="o4s-pill text-xs !py-1.5 !px-3">
              <span class="o4s-i18n-en">{t.en.hero_chip_1}</span>
              <span class="o4s-i18n-zh">{t.zh.hero_chip_1}</span>
            </span>
            <span class="o4s-pill text-xs !py-1.5 !px-3">
              <span class="o4s-i18n-en">{t.en.hero_chip_2}</span>
              <span class="o4s-i18n-zh">{t.zh.hero_chip_2}</span>
            </span>
            <span class="o4s-pill text-xs !py-1.5 !px-3">
              <span class="o4s-i18n-en">{t.en.hero_chip_3}</span>
              <span class="o4s-i18n-zh">{t.zh.hero_chip_3}</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="o4s-horizon max-w-6xl mx-auto"></div>

  <!-- ================= PROVIDERS ================= -->
  <section class="relative overflow-hidden o4s-cine-section border-y border-white/5">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <ParticleField density={64} />
      <div class="o4s-vignette absolute inset-0 opacity-60"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <p class="o4s-cine-kicker mb-3">
        <span class="o4s-i18n-en">{t.en.providers_kicker}</span>
        <span class="o4s-i18n-zh">{t.zh.providers_kicker}</span>
      </p>
      <h2 class="o4s-cine-title text-2xl md:text-3xl">
        <span class="o4s-i18n-en">{t.en.providers_title}</span>
        <span class="o4s-i18n-zh">{t.zh.providers_title}</span>
      </h2>
      <p class="text-muted text-sm mt-3 mb-10">
        <span class="o4s-i18n-en">{t.en.providers_sub}</span>
        <span class="o4s-i18n-zh">{t.zh.providers_sub}</span>
      </p>
      <ProviderOrbit providers={providers} />
    </div>
  </section>

  <!-- ================= PARADIGM ================= -->
  <section id="paradigm" class="o4s-cine-section relative">
    <div class="absolute inset-0 pointer-events-none opacity-40" aria-hidden="true">
      <ParticleField density={40} />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <p class="o4s-cine-kicker mb-5">
          <span class="o4s-i18n-en">{t.en.paradigm_badge} · {t.en.paradigm_badge_v}</span>
          <span class="o4s-i18n-zh">{t.zh.paradigm_badge} · {t.zh.paradigm_badge_v}</span>
        </p>
        <h2 class="o4s-cine-title text-3xl md:text-5xl">
          <span class="o4s-i18n-en">{t.en.paradigm_title_a} </span>
          <span class="o4s-i18n-zh">{t.zh.paradigm_title_a} </span>
          <span class="o4s-gradient-text">
            <span class="o4s-i18n-en">{t.en.paradigm_title_b}</span>
            <span class="o4s-i18n-zh">{t.zh.paradigm_title_b}</span>
          </span>
        </h2>
        <p class="o4s-cine-lead mt-6 mx-auto text-center">
          <span class="o4s-i18n-en">{t.en.paradigm_lead}</span>
          <span class="o4s-i18n-zh">{t.zh.paradigm_lead}</span>
        </p>
      </div>

      <div class="o4s-i18n-en">
        <ParadigmCompare rows={cmpRows} />
      </div>
      <div class="o4s-i18n-zh">
        <ParadigmCompare rows={cmpRowsZh} oldTitle="ReAct + tool_use" newTitle="Code-as-Action" />
      </div>

      <div class="max-w-4xl mx-auto mt-14">
        <CodeCard label="~/OpenAI4S · one cell" live="one round-trip" dots={true} accent="amber">
          <Fragment set:html={paradigmCode} />
        </CodeCard>
      </div>
    </div>
  </section>

  <div class="o4s-horizon max-w-5xl mx-auto"></div>

  <!-- ================= HIGHLIGHTS ================= -->
  <section id="highlights" class="o4s-cine-section relative">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <p class="o4s-cine-kicker mb-5">
          <span class="o4s-i18n-en">{t.en.highlights_badge} · {t.en.highlights_badge_v}</span>
          <span class="o4s-i18n-zh">{t.zh.highlights_badge} · {t.zh.highlights_badge_v}</span>
        </p>
        <h2 class="o4s-cine-title text-3xl md:text-5xl">
          <span class="o4s-i18n-en">{t.en.highlights_title_a} </span>
          <span class="o4s-i18n-zh">{t.zh.highlights_title_a} </span>
          <span class="o4s-gradient-text">
            <span class="o4s-i18n-en">{t.en.highlights_title_b}</span>
            <span class="o4s-i18n-zh">{t.zh.highlights_title_b}</span>
          </span>
        </h2>
        <p class="o4s-cine-lead mt-5 mx-auto text-center">
          <span class="o4s-i18n-en">{t.en.highlights_sub}</span>
          <span class="o4s-i18n-zh">{t.zh.highlights_sub}</span>
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {
          highlights.map((item) => (
            <div class="o4s-feature o4s-sheen">
              <div class="o4s-feature-icon">
                <Icon name={item.icon} class="w-5 h-5" />
              </div>
              <h3 class="text-lg font-bold font-heading text-gray-900 dark:text-white mb-2">
                <span class="o4s-i18n-en">{t.en[item.titleKey]}</span>
                <span class="o4s-i18n-zh">{t.zh[item.titleKey]}</span>
              </h3>
              <p class="text-muted text-sm leading-relaxed">
                <span class="o4s-i18n-en">{t.en[item.descKey]}</span>
                <span class="o4s-i18n-zh">{t.zh[item.descKey]}</span>
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= DEMOS ================= -->
  <section id="demos" class="relative overflow-hidden o4s-cine-section">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <ParticleField density={72} />
      <div class="o4s-vignette absolute inset-0"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <p class="o4s-cine-kicker mb-5">
          <span class="o4s-i18n-en">{t.en.demos_badge} · {t.en.demos_badge_v}</span>
          <span class="o4s-i18n-zh">{t.zh.demos_badge} · {t.zh.demos_badge_v}</span>
        </p>
        <h2 class="o4s-cine-title text-3xl md:text-5xl">
          <span class="o4s-i18n-en">{t.en.demos_title_a} </span>
          <span class="o4s-i18n-zh">{t.zh.demos_title_a} </span>
          <span class="o4s-gradient-text">
            <span class="o4s-i18n-en">{t.en.demos_title_b}</span>
            <span class="o4s-i18n-zh">{t.zh.demos_title_b}</span>
          </span>
        </h2>
        <p class="o4s-cine-lead mt-5 mx-auto text-center">
          <span class="o4s-i18n-en">{t.en.demos_sub}</span>
          <span class="o4s-i18n-zh">{t.zh.demos_sub}</span>
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6 lg:gap-8">
        {
          demos.map((d) => (
            <div>
              <div class="o4s-i18n-en">
