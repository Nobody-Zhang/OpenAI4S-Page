<script>
  // Lazy-load + autoplay demo videos on scroll; pause offscreen.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const vids = document.querySelectorAll<HTMLVideoElement>('video[data-src]');
  if (!reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          const v = e.target as HTMLVideoElement;
          if (e.isIntersecting) {
            if (!v.src) v.src = v.dataset.src || '';
            v.play().catch(() => {});
          } else {
            v.pause();
          }
        });
      },
      { threshold: 0.25 }
    );
    vids.forEach((v) => io.observe(v));
  }

  // Activate a demo (mouse or keyboard) to expand fullscreen with controls.
  const demoVids = document.querySelectorAll<HTMLVideoElement>('[data-demo] video');
  const expand = (v: HTMLVideoElement) => {
    if (!v.src) v.src = v.dataset.src || '';
    v.controls = true;
    const el = v as HTMLVideoElement & { webkitEnterFullscreen?: () => void };
    if (el.requestFullscreen) el.requestFullscreen().catch(() => {});
    else if (el.webkitEnterFullscreen) el.webkitEnterFullscreen();
  };
  demoVids.forEach((v) => {
    v.addEventListener('click', () => expand(v));
    v.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter' || ev.key === ' ') {
        ev.preventDefault();
        expand(v);
      }
    });
  });
  // Single document-level listener clears controls on all demos when leaving fullscreen.
  document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) demoVids.forEach((v) => (v.controls = false));
  });

  // Copy buttons — guard insecure contexts, catch failures, avoid re-entry label bug.
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    if (!btn.dataset.label) btn.dataset.label = btn.textContent || '';
    btn.addEventListener('click', async () => {
      if (btn.classList.contains('copied')) return;
      try {
        if (!navigator.clipboard?.writeText) throw new Error('clipboard unavailable');
        await navigator.clipboard.writeText(btn.dataset.copy || '');
        btn.classList.add('copied');
        btn.textContent = '✓ copied';
      } catch {
        btn.textContent = '⧉ select & copy';
      }
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.textContent = btn.dataset.label || '';
      }, 1400);
    });
  });
</script>
