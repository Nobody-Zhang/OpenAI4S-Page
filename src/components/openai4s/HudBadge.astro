---
interface Props {
  label: string;
  value?: string;
  tone?: 'cyan' | 'violet' | 'amber' | 'green';
  class?: string;
}
const { label, value, tone = 'cyan', class: className = '' } = Astro.props;
---

<span class:list={['o4s-hud-badge', `o4s-hud-badge--${tone}`, className]}>
  <span class="o4s-hud-badge__dot"></span>
  <span class="o4s-hud-badge__label">{label}</span>
  {value && <span class="o4s-hud-badge__value">{value}</span>}
</span>

<style>
  .o4s-hud-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--aw-font-mono), ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    border-radius: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--tone, var(--o4s-cyan)) 40%, var(--o4s-border));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--tone, var(--o4s-cyan)) 14%, transparent), transparent),
      color-mix(in srgb, var(--aw-color-bg-page) 55%, transparent);
    color: var(--tone, var(--o4s-cyan));
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--tone, var(--o4s-cyan)) 8%, transparent),
      0 0 18px -10px color-mix(in srgb, var(--tone, var(--o4s-cyan)) 55%, transparent);
    backdrop-filter: blur(8px);
  }
  .o4s-hud-badge--cyan {
    --tone: var(--o4s-cyan);
  }
  .o4s-hud-badge--violet {
    --tone: var(--o4s-violet);
  }
  .o4s-hud-badge--amber {
    --tone: var(--o4s-amber);
  }
  .o4s-hud-badge--green {
    --tone: var(--o4s-neon);
  }
  .o4s-hud-badge__dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: var(--tone, var(--o4s-cyan));
    box-shadow: 0 0 8px var(--tone, var(--o4s-cyan));
    animation: o4s-pulse 2s infinite;
  }
  .o4s-hud-badge__value {
    color: var(--aw-color-text-heading);
    letter-spacing: 0.04em;
    opacity: 0.9;
  }
</style>
