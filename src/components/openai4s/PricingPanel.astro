---
/**
 * Premium dual pricing panel — Self-host Free MIT vs Volcengine Ark ¥9.9/mo.
 *
 * Usage:
 *   <PricingPanel github="https://github.com/PKU-YuanGroup/OpenAI4S" arkImage={arkPlan} />
 *   <PricingPanel github={GITHUB}><Image slot="ark-image" src={arkPlan} alt="..." /></PricingPanel>
 */
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Image from '~/components/common/Image.astro';
import HudBadge from '~/components/openai4s/HudBadge.astro';

interface Props {
  /** GitHub repo URL for the free-tier CTA */
  github?: string;
  /** Optional ESM-imported image (or resolvable path) for the Ark plan screenshot */
  arkImage?: ImageMetadata | string | null;
  /** Alt text when arkImage prop is used */
  arkImageAlt?: string;
  /** Caption under the Ark screenshot */
  arkCaption?: string;
  /** Free-tier feature bullets */
  freeFeatures?: string[];
  /** Paid-tier feature bullets (shown when no ark image/slot) */
  arkFeatures?: string[];
  /** Free CTA label */
  freeCtaText?: string;
  /** Optional paid CTA href — when set, shows a secondary button under the Ark card */
  arkCtaHref?: string;
  /** Paid CTA label */
  arkCtaText?: string;
  /** Section heading overrides */
  title?: string;
  titleAccent?: string;
  subtitle?: string;
  class?: string;
}

const {
  github = 'https://github.com/PKU-YuanGroup/OpenAI4S',
  arkImage = null,
  arkImageAlt = 'Volcengine Ark Agent Plan — the Small tier is ¥9.9 / month',
  arkCaption = 'Volcengine Ark · Agent Plan (Personal) — entry “Small” tier ¥9.9 / month.',
  freeFeatures = [
    'Full Code-as-Action engine + web app',
    '24 Skills, live Notebook, versioned artifacts',
    'BYOC GPU compute (ssh / NVIDIA NIM)',
    'MIT license — clone, fork, self-host forever',
  ],
  arkFeatures = [
    'Doubao via Volcengine Ark “Small” plan',
    'No frontier-model API key required',
    'Pick the ark provider in the UI',
    'Claude-Science-class agent for pocket change',
  ],
  freeCtaText = 'Get it on GitHub',
  arkCtaHref,
  arkCtaText = 'Open Volcengine Ark',
  title = 'Two ways.',
  titleAccent = 'Both cheap.',
  subtitle = 'No frontier-model key required. Self-host free, or drive it for pocket change.',
  class: className = '',
} = Astro.props;

const hasArkImageSlot = Astro.slots.has('ark-image');
const showArkImage = Boolean(arkImage) || hasArkImageSlot;
---

<div class:list={['o4s-pricing-panel', className]}>
  <div class="text-center max-w-3xl mx-auto mb-12">
    <HudBadge label="COST" value="TWO PATHS" tone="amber" class="mb-5" />
    <h2 class="text-3xl md:text-5xl font-bold font-heading tracking-tight text-gray-900 dark:text-white mt-5">
      {title}{' '}
      <span class="o4s-gradient-text">{titleAccent}</span>
    </h2>
    {subtitle && <p class="mt-5 text-lg text-muted">{subtitle}</p>}
  </div>

  <div class="grid md:grid-cols-2 gap-6 items-stretch">
    <!-- ========== Self-host · Free MIT ========== -->
    <article class="nb-card p-8 h-full flex flex-col o4s-price-free">
      <p class="o4s-prompt">self-host</p>
      <div class="mt-3 flex items-baseline gap-2 flex-wrap">
        <span class="text-4xl md:text-5xl font-bold font-heading text-gray-900 dark:text-white">Free</span>
        <span class="text-muted font-mono text-sm">· MIT</span>
      </div>
      <p class="mt-4 text-muted leading-relaxed">
        Clone the repo, bring any key or none, all features. No frontier-model key required.
      </p>
      <ul class="mt-6 space-y-3 text-sm text-default flex-1">
        {
          freeFeatures.map((item) => (
            <li class="flex items-start gap-2">
              <Icon name="tabler:check" class="w-4 h-4 text-primary mt-0.5 shrink-0" aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
      <div class="mt-8">
        <Button
          variant="primary"
          href={github}
          target="_blank"
          icon="tabler:brand-github"
          text={freeCtaText}
          class="w-full sm:w-auto justify-center"
        />
      </div>
    </article>

    <!-- ========== Ark · ¥9.9/mo (hot amber glow) ========== -->
    <article class="nb-card o4s-price-hot p-8 h-full flex flex-col relative overflow-hidden">
      <div class="o4s-price-hot__glow" aria-hidden="true"></div>
      <div class="relative flex items-center justify-between gap-3">
        <p
          class="o4s-prompt"
          style="color: var(--o4s-amber); text-shadow: 0 0 18px color-mix(in srgb, var(--o4s-amber) 40%, transparent)"
        >
          doubao · volcengine ark
        </p>
        <span
          class="text-xs font-mono px-2.5 py-1 rounded-full shrink-0"
          style="background: color-mix(in srgb, var(--o4s-amber) 16%, transparent); color: var(--o4s-amber); border: 1px solid color-mix(in srgb, var(--o4s-amber) 35%, transparent)"
          >cheapest</span
        >
      </div>
      <div class="relative mt-3 flex items-baseline gap-2 flex-wrap">
        <span class="text-4xl md:text-5xl font-bold font-heading" style="color: var(--o4s-amber)">¥9.9</span>
        <span class="text-muted font-mono text-sm">/ month (≈ US$1.4)</span>
      </div>
      <p class="relative mt-4 text-muted leading-relaxed">
        A Claude-Science-class agent for less than a cup of coffee. Pick the <code class="o4s-chip">ark</code> provider
        in the UI.
      </p>

      {
        showArkImage ? (
          <>
            <div
              class="relative mt-6 rounded-xl overflow-hidden border flex-1"
              style="border-color: color-mix(in srgb, var(--o4s-amber) 25%, var(--o4s-border))"
            >
              {hasArkImageSlot ? (
                <slot name="ark-image" />
              ) : (
                arkImage && <Image src={arkImage} alt={arkImageAlt} layout="responsive" loading="lazy" class="w-full h-auto" />
              )}
            </div>
            {arkCaption && <p class="relative mt-3 text-xs text-muted font-mono">{arkCaption}</p>}
          </>
        ) : (
          <ul class="relative mt-6 space-y-3 text-sm text-default flex-1">
            {arkFeatures.map((item) => (
              <li class="flex items-start gap-2">
                <Icon name="tabler:check" class="w-4 h-4 mt-0.5 shrink-0 text-amber-400" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        )
      }

      {
        arkCtaHref && (
          <div class="relative mt-8">
            <a href={arkCtaHref} class="btn-ghost w-full sm:w-auto justify-center" target="_blank" rel="noopener noreferrer">
              {arkCtaText}
            </a>
          </div>
        )
      }
    </article>
  </div>
</div>

<style>
  .o4s-price-hot__glow {
    pointer-events: none;
    position: absolute;
    inset: -20% -10% auto auto;
    width: 70%;
    height: 55%;
    background: radial-gradient(
      ellipse at 70% 20%,
      color-mix(in srgb, var(--o4s-amber) 28%, transparent) 0%,
      color-mix(in srgb, var(--o4s-amber) 8%, transparent) 45%,
      transparent 70%
    );
    filter: blur(2px);
  }

  .o4s-price-free:hover {
    border-color: color-mix(in srgb, var(--o4s-cyan) 35%, var(--o4s-border));
  }

  @media (prefers-reduced-motion: reduce) {
    .o4s-price-hot__glow {
      filter: none;
    }
  }
</style>
