---
import penta from '~/assets/openai4s/penta.gif';
import pentaFrame from '~/assets/openai4s/penta-frame.png';
---

<span class="inline-flex items-center gap-2 self-center">
  <picture>
    <source srcset={pentaFrame.src} media="(prefers-reduced-motion: reduce)" />
    <img
      src={penta.src}
      alt="OpenAI4S logo"
      width="30"
      height="30"
      class="w-[30px] h-[30px] shrink-0 rounded-md"
      loading="eager"
      decoding="async"
    />
  </picture>
  <span
    class="text-2xl md:text-xl font-bold tracking-tight font-heading text-gray-900 dark:text-white whitespace-nowrap"
  >
    OpenAI4S
  </span>
</span>
